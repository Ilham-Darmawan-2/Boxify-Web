# =============================================================================
# Boxify Backend — Environment Configuration
# =============================================================================
# Copy this file to `.env` and adjust the values for your environment:
#
#   cp .env.example .env
#
# The application loads this file automatically on startup via python-dotenv.
# All variables below have sensible defaults for local development.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (MySQL)
# ---------------------------------------------------------------------------
# SQLAlchemy connection URL.
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<database>
MYSQL_URL=mysql+pymysql://samtek_user:samtek123@localhost:3306/boxify

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
# Secret key used to sign and verify JWT tokens.
# IMPORTANT: Change this to a strong, random value in production!
JWT_SECRET_KEY=boxify-dev-secret-change-in-production

# Token expiration time in minutes (default: 1440 = 24 hours).
JWT_EXPIRE_MINUTES=1440

# JWT signing algorithm.
JWT_ALGORITHM=HS256

# ---------------------------------------------------------------------------
# File Storage
# ---------------------------------------------------------------------------
# Root directory for project data (images, annotations, models).
# Can be an absolute path or relative to the backend/ directory.
# Default: ./data/projects
PROJECTS_DIR=./data/projects

# Maximum upload size in megabytes (default: 500 MB).
MAX_UPLOAD_SIZE_MB=500

# ---------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins. Use "*" to allow all.
CORS_ALLOW_ORIGINS=*

# Comma-separated list of allowed HTTP methods.
CORS_ALLOW_METHODS=*

# Comma-separated list of allowed headers.
CORS_ALLOW_HEADERS=*

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# Host and port for uvicorn (used if running via `python -m api.main`).
APP_HOST=0.0.0.0
APP_PORT=8000
